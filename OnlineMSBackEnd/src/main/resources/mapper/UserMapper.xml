<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.daox.online.mapper.UserMapper">

    <select id="findByIdIn" resultType="com.daox.online.entity.mysql.Users">
        -- 为了安全和性能，只查询必要字段，如 id, name, student_number 等
        SELECT
        id,
        nickname,
        identifier,
        avatar_url
        FROM
        users
        WHERE
        id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        <if test="ids == null or ids.size() == 0">
            AND 1 = 0
        </if>
    </select>

</mapper>