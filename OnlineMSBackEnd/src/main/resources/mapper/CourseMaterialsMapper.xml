<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.daox.online.mapper.CourseMaterialsMapper">
    <select id="countBySectionIds" resultType="long">
        SELECT COUNT(*) FROM course_materials
        WHERE is_deleted = 0 AND section_id IN
        <foreach collection="sectionIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>